{
  "manifest_version": 3,
  "name": "CheckMate AI",
  "version": "1.0.4",
  "description": "AI-powered fact-checking for YouTube videos.",
  "permissions": [
    "sidePanel",
    "tabs",
    "activeTab",
    "storage"
  ],
  "host_permissions": [
    "https://www.youtube.com/*",
    "http://localhost:3000/*"
  ],
  "action": {
    "default_title": "Open CheckMate AI"
  },
  "side_panel": {
    "default_path": "index.html"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/*"],
      "js": ["content.js"]
    }
  ]
}
